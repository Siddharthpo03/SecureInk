{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    // "moduleResolution": "Node",

    "rootDir": "./src",
    "outDir": "./dist",
    "removeComments": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"]
}
